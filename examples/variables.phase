entry {
    -- 4 literal types, plus void for
    -- function return types and
    -- null values
    let number: int = 10
    let decimal: float = 10.0
    let word: str = "Ten"
    let flag: bool = true

    -- Tuple destructuring
    let (num1, num2): int = (1, 2)
    let (num3, num4): int = (num2, num1)

    -- You can also declare a variable
    -- without assigning a value, but
    -- it will assume null type
    let x: int
    
    out(x)
}

-- void
