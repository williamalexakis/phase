func fibonacci(n: int): void {
    let (a, b): int = (0, 1)
    let (next, count): int = (b, 1)
    
    while count <= n {
        out(next)
        count += 1
        next = a + b
        a = b
        b = next
    }
}

entry {
    fibonacci(10)
}

